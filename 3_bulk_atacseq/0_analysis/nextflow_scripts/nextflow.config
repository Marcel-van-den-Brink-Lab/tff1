// =============================================================================
// nextflow.config — Cluster-specific configuration for nf-core/atacseq v2.1.2
// Project: atacseq_pipeline | https://nf-co.re/atacseq/2.1.2/
//
// This file controls HOW the pipeline runs on your HPC:
//   - Singularity container settings
//   - SLURM executor settings
//   - Process resource defaults and error retry logic
//   - Pipeline-level resource caps (40 CPUs / 128 GB RAM — match your HPC)
//   - Execution reports (timeline, trace, HTML report)
//
// Pipeline-level biological parameters (genome, outdir, etc.) live in
// params.yml — not here.
// =============================================================================

// ---------------------------------------------------------------------------
// Singularity
//
// enabled    : use Singularity containers for all processes
// autoMounts : automatically bind-mount host paths into the container so that
//              input/output paths resolve correctly without manual --bind flags
// cacheDir   : where pulled .sif images are stored and reused between runs
//              (set via environment variable, falls back to $HOME path)
// ---------------------------------------------------------------------------
singularity {
    enabled    = true
    autoMounts = true
    cacheDir   = "${System.getenv('NXF_SINGULARITY_CACHEDIR') ?: "${System.getenv('HOME')}/.singularity_cache/nf-core"}"
    // Uncomment and adjust if your HPC needs explicit bind paths:
    // runOptions = '--bind /scratch:/scratch'
}

// ---------------------------------------------------------------------------
// Process defaults (SLURM executor + retry logic)
//
// executor   : submit each pipeline task as a separate SLURM job
// queue      : SLURM partition; change to match your cluster
// errorStrategy: retry on memory/signal errors (OOM, SIGKILL, etc.)
//              other failures end the task immediately ('finish')
// maxRetries : retry failed tasks up to 3 times
//              nf-core pipelines typically scale memory with task.attempt
// ---------------------------------------------------------------------------
process {
    executor = 'slurm'

    // Default SLURM partition — fill in your partition name.
    // To use different partitions per process label, set queue inside
    // each withLabel block below.
    queue = 'compute'  // <-- required

    // Retry on exit codes typically caused by out-of-memory or preemption.
    // 'finish' means: let running tasks complete, then fail the workflow.
    errorStrategy = { task.exitStatus in [104, 134, 137, 139, 140, 143, 247] ? 'retry' : 'finish' }
    maxRetries    = 3

    // Uncomment to pass extra SBATCH directives to every job, e.g. account:
    // clusterOptions = '--account=MY_PROJECT_ACCOUNT'
}

// ---------------------------------------------------------------------------
// Executor settings
//
// queueSize      : maximum number of SLURM jobs submitted simultaneously.
//                  Reduce this if your HPC has strict fair-share limits.
//                  Adjust based on your cluster's scheduler policy.
// submitRateLimit: limit job submission rate to avoid overwhelming the scheduler
//                  '10 sec' = submit at most 10 jobs per second
// ---------------------------------------------------------------------------
executor {
    queueSize       = 50   // adjust based on HPC fair-share / policy limits
    submitRateLimit = '10 sec'
}

// ---------------------------------------------------------------------------
// Pipeline-level resource caps
//
// These act as a hard ceiling on any single task. Individual task resources
// are defined by nf-core process labels; these params.max_* values prevent
// the pipeline from requesting more than the node can provide.
//
// Values here match the HPC node limits: 40 CPUs / 128 GB RAM.
// ---------------------------------------------------------------------------
params {
    max_memory = '128.GB'  // matches HPC node limit of 128 GB RAM
    max_cpus   = 40        // matches HPC node limit of 40 CPUs
    max_time   = '72.h'    // matches SLURM --time in run_atacseq.slurm
}

// ---------------------------------------------------------------------------
// Execution reports
//
// These files are generated in results/pipeline_info/ after the run.
// They are invaluable for debugging failures and tuning resource requests.
//   timeline : Gantt-chart HTML showing when each task ran
//   report   : HTML report with CPU/memory usage per task
//   trace    : TSV file with per-task resource usage (parseable)
// ---------------------------------------------------------------------------
timeline {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_timeline.html"
    overwrite = true
}

report {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_report.html"
    overwrite = true
}

trace {
    enabled   = true
    file      = "${params.outdir}/pipeline_info/execution_trace.txt"
    overwrite = true
}
